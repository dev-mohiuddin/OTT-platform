# Core
MONGODB_URI="mongodb://localhost:27017/ott_platform"
MONGODB_DB_NAME="ott_platform"
REDIS_URL="redis://localhost:6379"
REDIS_ENABLED="true"
REDIS_TTL_ACCESS_SNAPSHOT_SECONDS="600"
REDIS_TTL_AUTH_ATTEMPT_SECONDS="900"
API_RATE_LIMIT_WINDOW_SECONDS="60"
API_RATE_LIMIT_MAX_REQUESTS="120"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
# Use true when running behind a proxy/tunnel in development
AUTH_TRUST_HOST="true"

# Google OAuth
GOOGLE_CLIENT_ID="replace-with-google-client-id"
GOOGLE_CLIENT_SECRET="replace-with-google-client-secret"
# Set true if you want Google login to link with existing same-email accounts
GOOGLE_ALLOW_EMAIL_ACCOUNT_LINKING="false"

# SMTP (for email verification + forgot/reset code)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
# Keep this as a string: "true" or "false"
SMTP_SECURE="true"
SMTP_USER="replace-with-email-address"
# For Gmail, this must be a Google App Password
SMTP_PASS="replace-with-app-password"
SMTP_FROM="no-reply@example.com"

# Auth policies
AUTH_CODE_EXPIRY_MINUTES="10"
PASSWORD_RESET_CODE_EXPIRY_MINUTES="15"

# Super admin seed
SUPER_ADMIN_EMAIL="admin@admin.com"
SUPER_ADMIN_PASSWORD="12345678"

# Existing project defaults
DEFAULT_COUNTRY_CODE="BD"
DEFAULT_LOCALE="bn-BD"
DEFAULT_CURRENCY="BDT"
LOG_LEVEL="info"
